# ── Frontend (Next.js) ───────────────────────────────────────────────────────
# Copy to apps/web/.env.local and fill in your values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Backend (FastAPI) ────────────────────────────────────────────────────────
# Copy to apps/api/.env and fill in your values
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
ENVIRONMENT=development
