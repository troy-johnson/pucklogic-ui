{
  "manifest_version": 3,
  "name": "PuckLogic Draft Sync",
  "description": "Sync live draft picks into PuckLogic draft sessions.",
  "version": "0.1.0",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.pucklogic.com/*",
    "https://fantasy.espn.com/*",
    "https://sports.yahoo.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://fantasy.espn.com/*"],
      "js": ["espn.js"]
    },
    {
      "matches": ["https://sports.yahoo.com/*"],
      "js": ["yahoo.js"]
    }
  ]
}
